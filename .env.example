# Apple Music API Configuration Example
# Copy this file to .env and fill in your actual credentials
# Get your credentials from: https://developer.apple.com/account/resources/authkeys/list

# Your MusicKit Developer Token (JWT)
# You need to generate this token using your private key, key ID, and team ID
# See: https://developer.apple.com/documentation/applemusicapi/generating_developer_tokens
VITE_APPLE_MUSIC_DEVELOPER_TOKEN=your_jwt_token_here

# Alternative: If you want to generate JWT in the browser (NOT recommended for production)
# You'll need these values from Apple Developer Portal:
# VITE_APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
# VITE_APPLE_MUSIC_KEY_ID=YOUR_KEY_ID_HERE
# VITE_APPLE_MUSIC_TEAM_KEY=YOUR_TEAM_ID_HERE

# OpenWeather API Configuration
# Get your free API key from: https://openweathermap.org/api
# Sign up and get your API key from the API keys section
VITE_OPENWEATHER_API_KEY=your_api_key_here

# Backend API Configuration
# Your backend server URL for contact form and other API calls
# Default: http://localhost:3000
VITE_BACKEND_API_URL=http://localhost:3000
